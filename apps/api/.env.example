# API Server
# Port for the NestJS backend server
PORT=3000

# CORS
# CORS origin for frontend (comma-separated for multiple origins)
# Use "*" to allow all origins (development only)
CORS_ORIGIN="*"

# Node Environment
NODE_ENV=development

# JWT Configuration
# Secret key for signing JWT tokens (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Access token expiration time (e.g., 15m, 1h, 1d)
JWT_EXPIRES_IN=1h
# Refresh token expiration time (e.g., 7d, 30d)
JWT_REFRESH_EXPIRES_IN=30d

# WeChat Mini Program Configuration
# 微信小程序 AppID
WX_APP_ID=
# 微信小程序 AppSecret (请勿泄露！)
WX_APP_SECRET=

# File Storage Configuration
# File storage provider: local | aliyun-oss
FILE_STORAGE_PROVIDER=aliyun-oss

# Local Storage Configuration
# Path for local file uploads
UPLOAD_PATH=./uploads

# Aliyun OSS Configuration
# OSS endpoint (e.g., oss-cn-hangzhou.aliyuncs.com)
OSS_ENDPOINT=your-oss-endpoint
# OSS bucket name
OSS_BUCKET=your-bucket-name
# OSS access key ID
OSS_ACCESS_KEY_ID=your-access-key-id
# OSS access key secret
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS region
OSS_REGION=oss-cn-hangzhou
