# 生产环境配置模板
# 复制此文件为 .env.prod 并填写实际值
#
# 注意：此配置使用外部数据库，不包含 PostgreSQL 容器
# 请确保已配置好外部数据库服务

# ===========================================
# Docker Registry 配置
# ===========================================
# GitHub Container Registry 用户名（通常是你的 GitHub 用户名）
DOCKER_USERNAME=your-github-username
# Docker 镜像仓库地址（使用 GitHub Container Registry）
REGISTRY=ghcr.io
# 镜像名称前缀
IMAGE_PREFIX=your-github-username/feedbackhub
# 镜像标签（版本号）
TAG=latest

# ===========================================
# 数据库配置（外部数据库）
# ===========================================
# 外部数据库连接字符串（必填！）
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 示例：
# - 云数据库：postgresql://user:pass@xxx.postgres.database.azure.com:5432/feedbackhub
# - 本地数据库：postgresql://postgres:password@localhost:5432/feedbackhub
DATABASE_URL=postgresql://postgres:your-password@your-database-host:5432/feedbackhub

# ===========================================
# API 服务配置
# ===========================================
# API 服务端口
API_PORT=3000
# Node.js 环境
NODE_ENV=production
# CORS 源（多个用逗号分隔，生产环境建议指定具体域名）
CORS_ORIGIN=https://your-domain.com

# ===========================================
# JWT 认证配置
# ===========================================
# JWT 密钥（生产环境必须设置强密码！）
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
# Access token 过期时间（例如：1h, 7d）
JWT_EXPIRES_IN=1h
# Refresh token 过期时间（例如：7d, 30d）
JWT_REFRESH_EXPIRES_IN=30d

# ===========================================
# 微信小程序配置
# ===========================================
# 微信小程序 AppID
WX_APP_ID=your-wechat-mini-program-appid
# 微信小程序 AppSecret（请勿泄露！）
WX_APP_SECRET=your-wechat-mini-program-appsecret

# ===========================================
# 文件存储配置
# ===========================================
# 文件存储提供商: local | aliyun-oss
FILE_STORAGE_PROVIDER=aliyun-oss

# 本地存储配置（如果 FILE_STORAGE_PROVIDER=local）
# 本地文件上传路径
UPLOAD_PATH=./uploads

# 阿里云 OSS 配置（如果 FILE_STORAGE_PROVIDER=aliyun-oss）
# OSS endpoint（例如：oss-cn-hangzhou.aliyuncs.com）
OSS_ENDPOINT=oss-cn-zhangjiakou.aliyuncs.com
# OSS bucket 名称
OSS_BUCKET=your-bucket-name
# OSS Access Key ID
OSS_ACCESS_KEY_ID=your-access-key-id
# OSS Access Key Secret
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# OSS Region
OSS_REGION=oss-cn-zhangjiakou
# 是否使用签名 URL（true/false，公共读 bucket 设为 false）
OSS_USE_SIGNED_URL=false

# ===========================================
# Admin 前端配置
# ===========================================
# Admin 前端端口
ADMIN_PORT=80
# API 地址（前端访问后端的地址，生产环境改为实际域名）
VITE_API_URL=http://localhost:3000/trpc

# ===========================================
# 日志配置（可选）
# ===========================================
# 日志级别: error, warn, info, debug
LOG_LEVEL=info
# 是否启用访问日志
ACCESS_LOG_ENABLED=true
