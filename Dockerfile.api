# Multi-stage Dockerfile for API (NestJS + tRPC + Prisma)

# Stage 1: Base - Dependencies
FROM node:22-alpine AS base
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@10.12.4

# Copy package files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json ./apps/api/
COPY infra/database/package.json ./infra/database/
COPY infra/shared/package.json ./infra/shared/

# Install dependencies with pnpm cache mount
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

# Stage 2: Development
FROM base AS development
WORKDIR /app
COPY . .

# Generate Prisma client
RUN pnpm --filter @opencode/database prisma generate

# Install all dependencies with hoisting for better compatibility
RUN pnpm install --frozen-lockfile --shamefully-hoist

# Expose port
EXPOSE 3000

# Start development server using workspace script
CMD ["pnpm", "dev:api"]

# Stage 3: Build
FROM base AS builder
WORKDIR /app
COPY . .

# Generate Prisma client first (required for TypeScript compilation)
RUN cd infra/database && npx prisma generate

# Build API
RUN pnpm --filter @opencode/api build

# Stage 4: Production
FROM node:22-alpine AS production
WORKDIR /app

# Install pnpm
RUN npm install -g pnpm@10.12.4

# Copy package files
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/api/package.json ./apps/api/
COPY infra/database/package.json ./infra/database/
COPY infra/shared/package.json ./infra/shared/

# Install production dependencies only with cache
RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --prod --frozen-lockfile

# Copy entrypoint script
COPY apps/api/entrypoint.sh ./apps/api/entrypoint.sh
RUN chmod +x ./apps/api/entrypoint.sh

# Copy built files
COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/infra/database/generated ./infra/database/generated
COPY --from=builder /app/infra/shared/dist ./infra/shared/dist
COPY --from=builder /app/infra/database/prisma ./infra/database/prisma

# Expose port
EXPOSE 3000

# Set entrypoint to run migrations before starting
ENTRYPOINT ["./apps/api/entrypoint.sh"]
